HF_TOKEN=HUGGINGFACE_TOKEN_HERE
MODEL_NAME=MODEL_NAME_HERE

# ============================================================
# Klangenan AI Microservice — Environment Variables
# Salin file ini ke .env dan isi nilainya
# JANGAN commit .env ke git!
# ============================================================

# ----------------------------------------------------------
# DATABASE
# ----------------------------------------------------------
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Harus pakai driver asyncpg (bukan psycopg2) untuk async support
#
# Contoh lokal:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# Log semua SQL query ke console (aktifkan saat debugging)
DB_ECHO=false

# ----------------------------------------------------------
# APP
# ----------------------------------------------------------
DEBUG=false
APP_NAME=APP_NAME_HERE

# ----------------------------------------------------------
# CORS — izinkan Next.js mengakses microservice ini
# ----------------------------------------------------------
# Untuk development:
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Untuk production, ganti dengan domain asli:
# ALLOWED_ORIGINS=["https://klangenan.com"]
